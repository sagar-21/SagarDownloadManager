{
  "manifest_version": 3,
  "name": "Download Manager Integration",
  "version": "1.0.0",
  "description": "Detects media on web pages and sends them to Download Manager for download.",

  "permissions": [
    "webRequest",
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://localhost:6336/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js":  ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Download Manager"
  },

  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches":   ["<all_urls>"]
    }
  ]
}
