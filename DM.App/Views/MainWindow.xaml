<ui:FluentWindow x:Class="DM.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Download Manager" Height="700" Width="1100"
        Icon="/Resources/app.ico"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <!-- Resources must be declared before they are referenced via StaticResource -->
    <ui:FluentWindow.Resources>
        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" CornerRadius="7" Margin="0,1" Padding="12,10">
                            <Border.Background>
                                <SolidColorBrush Color="Transparent"/>
                            </Border.Background>
                            <Grid>
                                <!-- Accent selection bar -->
                                <Border x:Name="AccentBar"
                                        Width="3" CornerRadius="1.5"
                                        VerticalAlignment="Stretch"
                                        HorizontalAlignment="Left"
                                        Margin="-8,3,0,3"
                                        Background="{DynamicResource SystemAccentColorBrush}"
                                        Opacity="0"/>
                                <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="ItemBorder"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#18FFFFFF" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="ItemBorder"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="Transparent" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="ItemBorder"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#22FFFFFF" Duration="0:0:0.2"/>
                                            <DoubleAnimation
                                                Storyboard.TargetName="AccentBar"
                                                Storyboard.TargetProperty="Opacity"
                                                To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="ItemBorder"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="Transparent" Duration="0:0:0.2"/>
                                            <DoubleAnimation
                                                Storyboard.TargetName="AccentBar"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ TITLE BAR ═══ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="Transparent"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch">
                <!-- Minimize -->
                <Button x:Name="TitleMinBtn" Width="46" Height="40"
                        ToolTip="Minimize"
                        Click="TitleMinBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="MinBd" Background="Transparent" Width="46" Height="40">
                                <TextBlock Text="&#x2014;" Foreground="White" FontSize="10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="MinBd" Property="Background" Value="#28FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- Close to tray -->
                <Button x:Name="TitleCloseBtn" Width="46" Height="40"
                        ToolTip="Minimize to system tray"
                        Click="TitleCloseBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CloseBd" Background="Transparent" Width="46" Height="40">
                                <TextBlock Text="&#x2715;" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CloseBd" Property="Background" Value="#DEC0392B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Row="1" Grid.Column="0" Background="#CC191919"
                BorderBrush="#18FFFFFF" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20,26,20,18">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" CornerRadius="8"
                                Background="{DynamicResource SystemAccentColorBrush}">
                            <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="18"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Sagar Download" FontSize="13"
                                       FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Manager" FontSize="11"
                                       Foreground="White" Opacity="0.50" Margin="0,-1,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Footer: theme toggle -->
                <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,12">
                    <Border Height="1" Margin="8,4" Background="#14FFFFFF"/>
                    <Button x:Name="ThemeBtn" Margin="0,8,0,0"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="12,10" HorizontalContentAlignment="Left"
                            Click="ThemeBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="TB" CornerRadius="7" Padding="12,10">
                                    <Border.Background>
                                        <SolidColorBrush Color="Transparent"/>
                                    </Border.Background>
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation
                                                        Storyboard.TargetName="TB"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#18FFFFFF" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation
                                                        Storyboard.TargetName="TB"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="Transparent" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon x:Name="ThemeIcon" Symbol="WeatherMoon24"
                                           FontSize="16" Foreground="White"/>
                            <TextBlock x:Name="ThemeLabel" Text="Dark theme"
                                       Margin="10,0,0,0" VerticalAlignment="Center"
                                       Foreground="White" FontSize="13" Opacity="0.80"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Navigation list -->
                <ListBox x:Name="NavList"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionMode="Single"
                         Margin="8,4"
                         ItemContainerStyle="{StaticResource NavItemStyle}"
                         SelectionChanged="NavList_SelectionChanged">

                    <ListBoxItem Tag="downloads">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="16"
                                           Foreground="White"/>
                            <TextBlock Text="Downloads" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="White" FontSize="13"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="queue">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="List24" FontSize="16"
                                           Foreground="White"/>
                            <TextBlock Text="Queue" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="White" FontSize="13"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="history">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="History24" FontSize="16"
                                           Foreground="White"/>
                            <TextBlock Text="History" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="White" FontSize="13"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="settings">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="16"
                                           Foreground="White"/>
                            <TextBlock Text="Settings" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="White" FontSize="13"/>
                        </StackPanel>
                    </ListBoxItem>

                </ListBox>

            </DockPanel>
        </Border>

        <!-- ═══ CONTENT FRAME ═══ -->
        <Frame x:Name="ContentFrame" Grid.Row="1" Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="Transparent"/>

    </Grid>
</ui:FluentWindow>
