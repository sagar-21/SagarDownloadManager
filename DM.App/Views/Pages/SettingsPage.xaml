<Page x:Class="DM.App.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:DM.App.ViewModels"
      xmlns:conv="clr-namespace:DM.App.Converters"
      xmlns:s="clr-namespace:DM.Core.Settings;assembly=DM.Core"
      Background="Transparent">

    <Page.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:IntEqualsConverter               x:Key="TabVis"/>

        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground"         Value="White"/>
            <Setter Property="Padding"            Value="14,9"/>
            <Setter Property="Margin"             Value="6,1"/>
            <Setter Property="FontSize"           Value="13"/>
            <Setter Property="Cursor"             Value="Hand"/>
            <Setter Property="BorderThickness"    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#14FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SystemAccentColorBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentSwatchStyle" TargetType="Button">
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Margin"          Value="0,0,7,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Medium"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Opacity"     Value="0.45"/>
            <Setter Property="Margin"      Value="0,20,0,8"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background"  Value="#28FFFFFF"/>
            <Setter Property="Padding"     Value="18,14"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Opacity="0" Padding="28,22,28,16"
                Background="#14FFFFFF" BorderBrush="#0CFFFFFF" BorderThickness="0,0,0,1">
            <Border.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
        </Border>

        <!-- Nav + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left navigation ── -->
            <Border Grid.Column="0" BorderBrush="#10FFFFFF" BorderThickness="0,0,1,0"
                    Padding="4,12,4,12">
                <ListBox SelectedIndex="{Binding ActiveTab, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource NavItemStyle}"/>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem>General</ListBoxItem>
                    <ListBoxItem>Downloads</ListBoxItem>
                    <ListBoxItem>Speed &amp; Bandwidth</ListBoxItem>
                    <ListBoxItem>Video</ListBoxItem>
                    <ListBoxItem>Appearance</ListBoxItem>
                    <ListBoxItem>Advanced</ListBoxItem>
                </ListBox>
            </Border>

            <!-- ═════════════════════════════════════════════════
                 TAB 0 — GENERAL
            ═════════════════════════════════════════════════ -->
            <ScrollViewer Grid.Column="1"
                          Visibility="{Binding ActiveTab, Converter={StaticResource TabVis}, ConverterParameter=0}"
                          VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
                <StackPanel>
                    <TextBlock Text="DEFAULT FOLDER" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Download location" FontSize="14" FontWeight="Medium" Foreground="White" Margin="0,0,0,4"/>
                            <TextBlock Text="New downloads save here unless overridden per-download."
                                       FontSize="12" Foreground="White" Opacity="0.50" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding DefaultDownloadFolder, UpdateSourceTrigger=LostFocus}"
                                         Background="#18FFFFFF" Foreground="White"
                                         BorderBrush="#28FFFFFF" Padding="8,6"/>
                                <ui:Button Grid.Column="2" Appearance="Secondary" Padding="12,0"
                                           Click="BrowseFolder_Click">
                                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14"/>
                                </ui:Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="BEHAVIOR" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Monitor clipboard" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                    <TextBlock Text="Detect URLs copied to clipboard and offer to download"
                                               FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding ClipboardMonitor}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Border BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0" Padding="0,14,0,14">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Start minimized to tray" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                        <TextBlock Text="Launch in the system tray instead of the main window"
                                                   FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding StartInTray}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0" Padding="0,14,0,0">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Resume downloads on restart" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                        <TextBlock Text="Automatically continue incomplete downloads when the app starts"
                                                   FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding ResumeOnRestart}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="BROWSER EXTENSION" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Enable browser extension server" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                    <TextBlock FontSize="12" Foreground="White" Opacity="0.50" TextWrapping="Wrap" Margin="0,2,0,0">
                                        <Run>Runs a local HTTP server so the browser extension can send detected</Run>
                                        <Run>media to this app. Only accepts connections from localhost.</Run>
                                    </TextBlock>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding LocalServerEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Border BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0" Padding="0,14,0,0"
                                    IsEnabled="{Binding LocalServerEnabled}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Port" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                        <TextBlock Text="Restart the app after changing the port." FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBox Width="80"
                                                 Text="{Binding LocalServerPort, UpdateSourceTrigger=LostFocus}"
                                                 Background="#18FFFFFF" Foreground="White"
                                                 BorderBrush="#28FFFFFF" Padding="8,6"
                                                 TextAlignment="Center"/>
                                        <TextBlock Text="Default: 6336" FontSize="11" Foreground="White" Opacity="0.40"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ui:Button Appearance="Secondary" HorizontalAlignment="Left" Padding="14,7" Margin="0,8,0,0"
                               Command="{Binding ResetSectionCommand}"
                               CommandParameter="{x:Static s:SettingsSection.General}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowCounterclockwise24" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Reset General" FontSize="12"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ScrollViewer>

            <!-- ═════════════════════════════════════════════════
                 TAB 1 — DOWNLOADS
            ═════════════════════════════════════════════════ -->
            <ScrollViewer Grid.Column="1"
                          Visibility="{Binding ActiveTab, Converter={StaticResource TabVis}, ConverterParameter=1}"
                          VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
                <StackPanel>
                    <TextBlock Text="CONCURRENCY" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Max simultaneous downloads" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                <Border HorizontalAlignment="Right" Padding="8,2" CornerRadius="5"
                                        Background="{DynamicResource SystemAccentColorBrush}">
                                    <TextBlock Text="{Binding MaxConcurrentDownloads}" FontSize="12" Foreground="White" FontWeight="Medium"/>
                                </Border>
                            </Grid>
                            <Slider Value="{Binding MaxConcurrentDownloads}"
                                    Minimum="1" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="CONNECTION MODE" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <RadioButton Content="Auto-tune" Foreground="White" FontSize="13"
                                             IsChecked="{Binding ConnectionModeIsAuto}" Margin="0,0,16,0"/>
                                <RadioButton Content="Manual" Foreground="White" FontSize="13"
                                             IsChecked="{Binding ConnectionModeIsManual}"/>
                            </StackPanel>

                            <!-- Auto config -->
                            <StackPanel Visibility="{Binding ConnectionModeIsAuto, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Min connections" FontSize="13" Foreground="White" Opacity="0.75"/>
                                    <TextBox HorizontalAlignment="Right" Width="60"
                                             Text="{Binding AutoMinConnections, UpdateSourceTrigger=LostFocus}"
                                             Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="6,4"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Max connections" FontSize="13" Foreground="White" Opacity="0.75"/>
                                    <TextBox HorizontalAlignment="Right" Width="60"
                                             Text="{Binding AutoMaxConnections, UpdateSourceTrigger=LostFocus}"
                                             Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="6,4"/>
                                </Grid>
                                <TextBlock Text="Connection count is tuned automatically between min and max based on available bandwidth."
                                           FontSize="11" Foreground="White" Opacity="0.40" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Manual config -->
                            <StackPanel Visibility="{Binding ConnectionModeIsAuto, Converter={StaticResource InvBoolToVis}}">
                                <Grid>
                                    <TextBlock Text="Connections per file" FontSize="13" Foreground="White" Opacity="0.75"/>
                                    <TextBox HorizontalAlignment="Right" Width="60"
                                             Text="{Binding ManualConnectionCount, UpdateSourceTrigger=LostFocus}"
                                             Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="6,4"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="DEFAULT PRIORITY" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardBorder}">
                        <Grid>
                            <TextBlock Text="New download priority" FontSize="14" FontWeight="Medium" Foreground="White" VerticalAlignment="Center"/>
                            <ComboBox HorizontalAlignment="Right" Width="120" VerticalAlignment="Center"
                                      SelectedIndex="{Binding DefaultPriorityIndex}">
                                <ComboBoxItem>High</ComboBoxItem>
                                <ComboBoxItem>Normal</ComboBoxItem>
                                <ComboBoxItem>Low</ComboBoxItem>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <TextBlock Text="RETRY POLICY" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Max retries" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                <TextBox HorizontalAlignment="Right" Width="60"
                                         Text="{Binding RetryMaxRetries, UpdateSourceTrigger=LostFocus}"
                                         Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="6,4"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Initial delay (s)" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                <TextBox HorizontalAlignment="Right" Width="60"
                                         Text="{Binding RetryInitialDelaySecs, UpdateSourceTrigger=LostFocus}"
                                         Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="6,4"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Backoff multiplier" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                <TextBox HorizontalAlignment="Right" Width="60"
                                         Text="{Binding RetryBackoffMultiplier, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                         Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="6,4"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <ui:Button Appearance="Secondary" HorizontalAlignment="Left" Padding="14,7" Margin="0,8,0,0"
                               Command="{Binding ResetSectionCommand}"
                               CommandParameter="{x:Static s:SettingsSection.Downloads}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowCounterclockwise24" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Reset Downloads" FontSize="12"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ScrollViewer>

            <!-- ═════════════════════════════════════════════════
                 TAB 2 — SPEED & BANDWIDTH
            ═════════════════════════════════════════════════ -->
            <ScrollViewer Grid.Column="1"
                          Visibility="{Binding ActiveTab, Converter={StaticResource TabVis}, ConverterParameter=2}"
                          VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
                <StackPanel>
                    <TextBlock Text="SPEED LIMITS" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Global speed limit" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                    <TextBlock Text="Cap total bandwidth for all downloads combined"
                                               FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding GlobalSpeedLimitEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid IsEnabled="{Binding GlobalSpeedLimitEnabled}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding GlobalSpeedLimitKBps, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                                         Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="8,6"/>
                                <TextBlock Grid.Column="1" Text="KB/s"
                                           Foreground="White" Opacity="0.50" VerticalAlignment="Center" Margin="7,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Per-download limit" FontSize="14" FontWeight="Medium" Foreground="White" Margin="0,0,0,4"/>
                            <TextBlock Text="Default cap per file (0 = unlimited). Overridable per download."
                                       FontSize="12" Foreground="White" Opacity="0.50" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding PerDownloadSpeedLimitKBps, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                                         Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="8,6"/>
                                <TextBlock Grid.Column="1" Text="KB/s"
                                           Foreground="White" Opacity="0.50" VerticalAlignment="Center" Margin="7,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="SCHEDULER" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Auto-start / stop" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                <ToggleButton IsChecked="{Binding SchedulerEnabled}"
                                             HorizontalAlignment="Right" Height="22" Padding="8,0"/>
                            </Grid>
                            <Grid IsEnabled="{Binding SchedulerEnabled}" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Start" Grid.Column="0" FontSize="11" Foreground="White" Opacity="0.50" Margin="0,0,0,3"/>
                                <TextBlock Text="Stop"  Grid.Column="2" FontSize="11" Foreground="White" Opacity="0.50" Margin="4,0,0,3"/>
                                <TextBox Grid.Row="1" Grid.Column="0"
                                         Text="{Binding SchedulerStartTime, UpdateSourceTrigger=LostFocus}"
                                         Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="8,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="–" Foreground="White" Opacity="0.5" VerticalAlignment="Center" Margin="6,0"/>
                                <TextBox Grid.Row="1" Grid.Column="2"
                                         Text="{Binding SchedulerStopTime, UpdateSourceTrigger=LostFocus}"
                                         Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="8,6"/>
                            </Grid>
                            <ComboBox IsEnabled="{Binding SchedulerEnabled}"
                                      SelectedIndex="{Binding SchedulerRecurrenceIndex}">
                                <ComboBoxItem>Every day</ComboBoxItem>
                                <ComboBoxItem>Weekdays only</ComboBoxItem>
                                <ComboBoxItem>Once</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="TIME-BASED RULES" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Speed rules" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                <ui:Button Appearance="Transparent" HorizontalAlignment="Right"
                                           Padding="4,2" Height="22" MinWidth="0"
                                           Command="{Binding AddSpeedRuleCommand}" ToolTip="Add rule">
                                    <ui:SymbolIcon Symbol="Add24" FontSize="12" Foreground="White"/>
                                </ui:Button>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding SpeedRules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:SpeedRuleViewModel}">
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding From, UpdateSourceTrigger=LostFocus}"
                                                     Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="5,4" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="–" Foreground="White" Opacity="0.5"
                                                       VerticalAlignment="Center" Margin="4,0"/>
                                            <TextBox Grid.Column="2" Text="{Binding To, UpdateSourceTrigger=LostFocus}"
                                                     Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="5,4" FontSize="11"/>
                                            <TextBlock Grid.Column="3" Text="→" Foreground="White" Opacity="0.5"
                                                       VerticalAlignment="Center" Margin="4,0"/>
                                            <TextBox Grid.Column="4" Text="{Binding LimitKBps, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                                                     Background="#18FFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="5,4" FontSize="11"/>
                                            <ui:Button Grid.Column="5" Appearance="Transparent"
                                                       Padding="3,2" Height="22" MinWidth="0" Margin="3,0,0,0"
                                                       Command="{Binding DataContext.RemoveSpeedRuleCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}">
                                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="10" Foreground="White" Opacity="0.5"/>
                                            </ui:Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No rules. Click + to add one."
                                       FontSize="11" Foreground="White" Opacity="0.35" Margin="0,2,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SpeedRules.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <ui:Button Appearance="Secondary" HorizontalAlignment="Left" Padding="14,7" Margin="0,8,0,0"
                               Command="{Binding ResetSectionCommand}"
                               CommandParameter="{x:Static s:SettingsSection.SpeedAndSchedule}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowCounterclockwise24" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Reset Speed &amp; Bandwidth" FontSize="12"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ScrollViewer>

            <!-- ═════════════════════════════════════════════════
                 TAB 3 — VIDEO
            ═════════════════════════════════════════════════ -->
            <ScrollViewer Grid.Column="1"
                          Visibility="{Binding ActiveTab, Converter={StaticResource TabVis}, ConverterParameter=3}"
                          VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
                <StackPanel>
                    <TextBlock Text="VIDEO QUALITY" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <TextBlock Text="Default quality" FontSize="14" FontWeight="Medium" Foreground="White" VerticalAlignment="Center"/>
                                <ComboBox HorizontalAlignment="Right" Width="160" VerticalAlignment="Center"
                                          SelectedIndex="{Binding DefaultVideoQualityIndex}">
                                    <ComboBoxItem>Best available</ComboBoxItem>
                                    <ComboBoxItem>4K (2160p)</ComboBoxItem>
                                    <ComboBoxItem>1440p</ComboBoxItem>
                                    <ComboBoxItem>1080p (or best)</ComboBoxItem>
                                    <ComboBoxItem>720p</ComboBoxItem>
                                    <ComboBoxItem>480p</ComboBoxItem>
                                    <ComboBoxItem>360p</ComboBoxItem>
                                    <ComboBoxItem>Audio only</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                            <Border BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0" Padding="0,14,0,0">
                                <Grid>
                                    <TextBlock Text="Output format" FontSize="14" FontWeight="Medium" Foreground="White" VerticalAlignment="Center"/>
                                    <ComboBox HorizontalAlignment="Right" Width="100" VerticalAlignment="Center"
                                              SelectedIndex="{Binding VideoFormatIndex}">
                                        <ComboBoxItem>mp4</ComboBoxItem>
                                        <ComboBoxItem>mkv</ComboBoxItem>
                                        <ComboBoxItem>webm</ComboBoxItem>
                                        <ComboBoxItem>best (no re-encode)</ComboBoxItem>
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="DOWNLOAD OPTIONS" Style="{StaticResource SectionLabel}"/>

                    <!-- ── Card 1: All sites ── -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Width="8" Height="8" Fill="#FF4CAF50"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="1000+ sites supported out of the box"
                                           FontSize="13" FontWeight="SemiBold" Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Sites grid -->
                            <Border CornerRadius="6" Background="#18FFFFFF" Padding="10,8" Margin="0,0,0,12">
                                <WrapPanel Orientation="Horizontal">
                                    <TextBlock Text="YouTube" FontSize="11" Foreground="White" Opacity="0.70" Margin="0,0,10,3"/>
                                    <TextBlock Text="Instagram" FontSize="11" Foreground="White" Opacity="0.70" Margin="0,0,10,3"/>
                                    <TextBlock Text="TikTok" FontSize="11" Foreground="White" Opacity="0.70" Margin="0,0,10,3"/>
                                    <TextBlock Text="Twitter / X" FontSize="11" Foreground="White" Opacity="0.70" Margin="0,0,10,3"/>
                                    <TextBlock Text="Facebook" FontSize="11" Foreground="White" Opacity="0.70" Margin="0,0,10,3"/>
                                    <TextBlock Text="Vimeo" FontSize="11" Foreground="White" Opacity="0.70" Margin="0,0,10,3"/>
                                    <TextBlock Text="Twitch" FontSize="11" Foreground="White" Opacity="0.70" Margin="0,0,10,3"/>
                                    <TextBlock Text="Dailymotion" FontSize="11" Foreground="White" Opacity="0.70" Margin="0,0,10,3"/>
                                    <TextBlock Text="Reddit" FontSize="11" Foreground="White" Opacity="0.70" Margin="0,0,10,3"/>
                                    <TextBlock Text="Bilibili" FontSize="11" Foreground="White" Opacity="0.70" Margin="0,0,10,3"/>
                                    <TextBlock Text="SoundCloud" FontSize="11" Foreground="White" Opacity="0.70" Margin="0,0,10,3"/>
                                    <TextBlock Text="and 1000+ more" FontSize="11" Foreground="White" Opacity="0.40" Margin="0,0,0,3"/>
                                </WrapPanel>
                            </Border>

                            <!-- Geo-bypass toggle -->
                            <Border BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Geographic restriction bypass" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                        <TextBlock FontSize="12" Foreground="White" Opacity="0.50"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"
                                                   Text="Bypass region-blocked content on any site by faking location headers. Enable if a video says 'not available in your country'."/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding GeoBypass}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── Card 2: YouTube-specific ── -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="YouTube" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                <Border CornerRadius="4" Background="#22FFFFFF" Padding="6,2"
                                        Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="SITE-SPECIFIC" FontSize="10" FontWeight="Medium"
                                               Foreground="White" Opacity="0.5"/>
                                </Border>
                            </StackPanel>
                            <TextBlock FontSize="12" Foreground="White" Opacity="0.55"
                                       TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="These settings only apply to YouTube. Other sites use their own built-in extractors and work automatically."/>

                            <!-- Player client -->
                            <Border BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Player client" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                        <TextBlock FontSize="11" Foreground="White" Opacity="0.45"
                                                   TextWrapping="Wrap" Margin="0,3,120,0"
                                                   Text="Smart mode tries Android VR → TV Embedded → iOS in order. TV Embedded also bypasses age-restricted videos without cookies."/>
                                    </StackPanel>
                                    <ComboBox HorizontalAlignment="Right" Width="200" VerticalAlignment="Center"
                                              SelectedIndex="{Binding PlayerClientIndex}">
                                        <ComboBoxItem>Smart — auto-fallback (recommended)</ComboBoxItem>
                                        <ComboBoxItem>Android VR only</ComboBoxItem>
                                        <ComboBoxItem>TV Embedded (age restriction)</ComboBoxItem>
                                        <ComboBoxItem>iOS</ComboBoxItem>
                                        <ComboBoxItem>Web (standard)</ComboBoxItem>
                                        <ComboBoxItem>Android</ComboBoxItem>
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Cookies card (optional / collapsible) -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <!-- Header row — always visible -->
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Cookies file" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                        <Border CornerRadius="4" Background="#22FFFFFF" Padding="6,2"
                                                Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="OPTIONAL" FontSize="10" FontWeight="Medium"
                                                       Foreground="White" Opacity="0.5"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0">
                                        Only needed for age-restricted or members-only videos
                                    </TextBlock>
                                </StackPanel>
                                <ToggleButton IsChecked="{Binding CookiesExpanded, Mode=TwoWay}"
                                             HorizontalAlignment="Right" VerticalAlignment="Center"
                                             Height="26" Padding="10,0" FontSize="11">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Foreground"   Value="White"/>
                                            <Setter Property="Background"   Value="#1AFFFFFF"/>
                                            <Setter Property="BorderBrush"  Value="#18FFFFFF"/>
                                            <Setter Property="Cursor"       Value="Hand"/>
                                            <Setter Property="Content"      Value="▼ Show"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Content" Value="▲ Hide"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#28FFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </Grid>

                            <!-- Collapsed file path summary (shown only when file is set and collapsed) -->
                            <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="White" Opacity="0.40"
                                       Text="{Binding CookiesFilePath}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasCookiesFile}" Value="True"/>
                                                    <Condition Binding="{Binding CookiesExpanded}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Expandable cookie content -->
                            <StackPanel Margin="0,14,0,0"
                                        Visibility="{Binding CookiesExpanded, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="12" Foreground="White" Opacity="0.55"
                                           TextWrapping="Wrap" Margin="0,0,0,10">
                                    Export a cookies.txt file from Chrome or Firefox using the
                                    "Get cookies.txt LOCALLY" browser extension, then select it here.
                                </TextBlock>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox Grid.Column="0"
                                                Text="{Binding CookiesFilePath, UpdateSourceTrigger=PropertyChanged}"
                                                Margin="0,0,8,0"
                                                FontSize="12"
                                                IsReadOnly="True"
                                                PlaceholderText="No cookies file selected"/>
                                    <Button Grid.Column="1" Padding="12,6" Margin="0,0,4,0"
                                            Click="CookiesBrowse_Click"
                                            Content="Browse…"
                                            FontSize="12"/>
                                    <Button Grid.Column="2" Padding="10,6"
                                            Click="CookiesClear_Click"
                                            FontSize="12"
                                            Visibility="{Binding HasCookiesFile, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✕" Margin="0,0,4,0" Opacity="0.7"/>
                                            <TextBlock Text="Clear"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="METADATA" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Embed subtitles" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                    <TextBlock Text="Download and embed available subtitle tracks"
                                               FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding EmbedSubtitles}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Border BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0" Padding="0,14,0,0">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Embed thumbnail" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                        <TextBlock Text="Embed the video thumbnail as cover art"
                                                   FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding EmbedThumbnail}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ui:Button Appearance="Secondary" HorizontalAlignment="Left" Padding="14,7" Margin="0,8,0,0"
                               Command="{Binding ResetSectionCommand}"
                               CommandParameter="{x:Static s:SettingsSection.Video}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowCounterclockwise24" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Reset Video" FontSize="12"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ScrollViewer>

            <!-- ═════════════════════════════════════════════════
                 TAB 4 — APPEARANCE
            ═════════════════════════════════════════════════ -->
            <ScrollViewer Grid.Column="1"
                          Visibility="{Binding ActiveTab, Converter={StaticResource TabVis}, ConverterParameter=4}"
                          VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
                <StackPanel>
                    <TextBlock Text="THEME" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource CardBorder}">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Color scheme" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                <TextBlock Text="Controls the overall app appearance"
                                           FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ComboBox HorizontalAlignment="Right" Width="140" VerticalAlignment="Center"
                                      SelectedIndex="{Binding ThemeIndex}">
                                <ComboBoxItem>Dark</ComboBoxItem>
                                <ComboBoxItem>Light</ComboBoxItem>
                                <ComboBoxItem>Follow system</ComboBoxItem>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <TextBlock Text="ACCENT COLOR" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardBorder}">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Accent color" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                <TextBlock Text="Highlight color used throughout the interface"
                                           FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource AccentSwatchStyle}" Background="#FF0078D4" Tag="#FF0078D4" ToolTip="Windows Blue"  Click="AccentSwatch_Click"/>
                                <Button Style="{StaticResource AccentSwatchStyle}" Background="#FF107C10" Tag="#FF107C10" ToolTip="Green"          Click="AccentSwatch_Click"/>
                                <Button Style="{StaticResource AccentSwatchStyle}" Background="#FFE81123" Tag="#FFE81123" ToolTip="Red"            Click="AccentSwatch_Click"/>
                                <Button Style="{StaticResource AccentSwatchStyle}" Background="#FFFF8C00" Tag="#FFFF8C00" ToolTip="Orange"         Click="AccentSwatch_Click"/>
                                <Button Style="{StaticResource AccentSwatchStyle}" Background="#FF744DA9" Tag="#FF744DA9" ToolTip="Purple"         Click="AccentSwatch_Click"/>
                                <Button Style="{StaticResource AccentSwatchStyle}" Background="#FFE3008C" Tag="#FFE3008C" ToolTip="Pink"           Click="AccentSwatch_Click"/>
                                <Button Style="{StaticResource AccentSwatchStyle}" Background="#FF038387" Tag="#FF038387" ToolTip="Teal"           Click="AccentSwatch_Click"/>
                                <Button Style="{StaticResource AccentSwatchStyle}" Background="#FFFFB900" Tag="#FFFFB900" ToolTip="Gold"           Click="AccentSwatch_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ui:Button Appearance="Secondary" HorizontalAlignment="Left" Padding="14,7" Margin="0,8,0,0"
                               Command="{Binding ResetSectionCommand}"
                               CommandParameter="{x:Static s:SettingsSection.Appearance}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowCounterclockwise24" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Reset Appearance" FontSize="12"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ScrollViewer>

            <!-- ═════════════════════════════════════════════════
                 TAB 5 — ADVANCED
            ═════════════════════════════════════════════════ -->
            <ScrollViewer Grid.Column="1"
                          Visibility="{Binding ActiveTab, Converter={StaticResource TabVis}, ConverterParameter=5}"
                          VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
                <StackPanel>
                    <TextBlock Text="INTEGRITY" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource CardBorder}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Auto-verify checksum" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                <TextBlock Text="Verify file integrity after every download when checksum is available"
                                           FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox IsChecked="{Binding AutoVerifyChecksum}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="FILE MANAGEMENT" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Auto-categorize downloads" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                    <TextBlock Text="Move completed files into category folders automatically"
                                               FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding CategorizationEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <Border Margin="0,12,0,0" Padding="0,12,0,0"
                                    BorderBrush="#18FFFFFF" BorderThickness="0,1,0,0"
                                    Visibility="{Binding CategorizationEnabled, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Category"     FontSize="11" Foreground="White" Opacity="0.45"/>
                                        <TextBlock Grid.Column="1" Text="Extensions"   FontSize="11" Foreground="White" Opacity="0.45"/>
                                        <TextBlock Grid.Column="2" Text="Target folder" FontSize="11" Foreground="White" Opacity="0.45" Margin="5,0,0,0"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding CategorizationRules}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:CategorizationRuleViewModel}">
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="28"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox Grid.Column="0" Margin="0,0,4,0"
                                                                Text="{Binding Name, UpdateSourceTrigger=LostFocus}"/>
                                                    <ui:TextBox Grid.Column="1" Margin="0,0,4,0"
                                                                Text="{Binding ExtensionsText, UpdateSourceTrigger=LostFocus}"/>
                                                    <ui:TextBox Grid.Column="2" Margin="0,0,4,0"
                                                                Text="{Binding TargetFolder, UpdateSourceTrigger=LostFocus}"/>
                                                    <ui:Button Grid.Column="3" Appearance="Transparent"
                                                               Padding="4" MinWidth="0"
                                                               Command="{Binding DataContext.RemoveCategorizationRuleCommand,
                                                                   RelativeSource={RelativeSource AncestorType=Page}}"
                                                               CommandParameter="{Binding}">
                                                        <ui:SymbolIcon Symbol="Delete24" FontSize="12" Foreground="#FFAAAAAA"/>
                                                    </ui:Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ui:Button Appearance="Secondary" Margin="0,8,0,0" Padding="12,6"
                                               Command="{Binding AddCategorizationRuleCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Add24" FontSize="12" Margin="0,0,5,0"/>
                                            <TextBlock Text="Add Rule" FontSize="12"/>
                                        </StackPanel>
                                    </ui:Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="POST-DOWNLOAD" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Notify on completion" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                    <TextBlock Text="Show a system notification for each finished download"
                                               FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding AlwaysNotify}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Border BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0" Padding="0,14,0,0">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="When queue finishes" FontSize="14" FontWeight="Medium" Foreground="White"/>
                                        <TextBlock Text="Action to perform after all downloads complete"
                                                   FontSize="12" Foreground="White" Opacity="0.50" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ComboBox HorizontalAlignment="Right" Width="160" VerticalAlignment="Center"
                                              SelectedIndex="{Binding QueueFinishActionIndex}">
                                        <ComboBoxItem>None</ComboBoxItem>
                                        <ComboBoxItem>Show notification</ComboBoxItem>
                                        <ComboBoxItem>Sleep</ComboBoxItem>
                                        <ComboBoxItem>Shutdown (60 s)</ComboBoxItem>
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Reset Advanced + Reset All -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Appearance="Secondary" Padding="14,7" Margin="0,0,8,0"
                                   Command="{Binding ResetSectionCommand}"
                                   CommandParameter="{x:Static s:SettingsSection.PostDownload}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowCounterclockwise24" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="Reset Advanced" FontSize="12"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Appearance="Caution" Padding="14,7"
                                   Command="{Binding ResetAllCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Delete24" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="Reset All Settings" FontSize="12"/>
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>

                    <!-- About -->
                    <TextBlock Text="ABOUT" Style="{StaticResource SectionLabel}"/>
                    <Border CornerRadius="10" Background="#28FFFFFF" Padding="18,16" Margin="0,0,0,8">
                        <StackPanel>
                            <!-- App name + version -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="22"
                                               Foreground="{DynamicResource SystemAccentColorBrush}"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Sagar Download Manager"
                                               FontSize="16" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="v1.0.0" FontSize="11"
                                               Foreground="White" Opacity="0.45" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Separator Margin="0,14,0,12" Background="#18FFFFFF"/>

                            <!-- Developer info -->
                            <TextBlock FontSize="13" Foreground="White" FontWeight="Medium"
                                       Margin="0,0,0,4">Developed by Sagar Vishwakarma</TextBlock>
                            <TextBlock FontSize="12" Foreground="White" Opacity="0.55"
                                       Margin="0,0,0,14" TextWrapping="Wrap">
                                Multi-connection HTTP/HTTPS downloader with yt-dlp video support
                                for 1000+ streaming sites.
                            </TextBlock>

                            <!-- LinkedIn button -->
                            <ui:Button Appearance="Secondary" HorizontalAlignment="Left"
                                       Padding="14,8" Margin="0,0,0,10"
                                       Click="LinkedIn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Person24" FontSize="13" Margin="0,0,7,0"/>
                                    <TextBlock FontSize="12">linkedin.com/in/sagar-vishwakarma-b1a015129</TextBlock>
                                </StackPanel>
                            </ui:Button>

                            <Separator Margin="0,0,0,12" Background="#18FFFFFF"/>
                            <ui:Button Appearance="Secondary" HorizontalAlignment="Left" Padding="14,8"
                                       Click="Licenses_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="DocumentText24" FontSize="13" Margin="0,0,7,0"/>
                                    <TextBlock Text="View Open-Source Licenses" FontSize="12"/>
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>

</Page>
