<Page x:Class="DM.App.Views.Pages.DownloadsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:DM.App.ViewModels"
      xmlns:conv="clr-namespace:DM.App.Converters"
      xmlns:controls="clr-namespace:DM.App.Controls"
      Background="Transparent">

    <Page.Resources>
        <conv:BoolToVisibilityConverter         x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter  x:Key="InverseBoolToVis"/>
        <conv:ProgressToPercentConverter        x:Key="PercentConv"/>
        <conv:StatusToBadgeBackgroundConverter  x:Key="StatusBgConv"/>
        <conv:StatusToForegroundConverter       x:Key="StatusFgConv"/>

        <!-- ══════════════════════════════════════════════════
             Download card DataTemplate
             ══════════════════════════════════════════════════ -->
        <DataTemplate x:Key="CardTemplate" DataType="{x:Type vm:DownloadItemViewModel}">

            <!-- DataTemplate-level triggers: glow pulse while Downloading -->
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="GlowBegin">
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetName="GlowBorder"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.20" To="0.75"
                                                 Duration="0:0:1.4">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="GlowBegin"/>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="GlowBorder"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.4"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>

            <!-- Card root: starts transparent + 14px below, animates in on Loaded -->
            <Grid Margin="0,0,0,10" Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction>
                                        <QuarticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                    From="14" To="0" Duration="0:0:0.32">
                                    <DoubleAnimation.EasingFunction>
                                        <QuarticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>

                <!-- Card body -->
                <Border CornerRadius="10" Padding="18,14"
                        Background="#28FFFFFF">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- 0: header: filename + badge + buttons -->
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>  <!-- 2: subtitle: URL + size -->
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="4"/>     <!-- 4: progress bar -->
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>  <!-- 6: stats: percent + speed + graph + ETA -->
                            <RowDefinition Height="Auto"/>  <!-- 7: error message (Failed state) -->
                        </Grid.RowDefinitions>

                        <!-- ── Row 0: filename + status badge + action buttons ── -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="Document24" FontSize="18"
                                               Foreground="White" Opacity="0.65"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding FileName}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- Right cluster: badge + buttons -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <Border Padding="9,3" CornerRadius="12" Margin="0,0,6,0"
                                        Background="{Binding Status, Converter={StaticResource StatusBgConv}}">
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="11" FontWeight="Medium"
                                               Foreground="{Binding Status, Converter={StaticResource StatusFgConv}}"/>
                                </Border>

                                <!-- Pause — visible only while Downloading -->
                                <ui:Button Appearance="Transparent" Padding="5,4" Margin="1,0,0,0"
                                           Height="26" MinWidth="0"
                                           Command="{Binding PauseResumeCommand}"
                                           ToolTip="Pause"
                                           Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                                    <ui:SymbolIcon Symbol="Pause24" FontSize="13" Foreground="White"/>
                                </ui:Button>

                                <!-- Resume — visible only when Paused -->
                                <ui:Button Appearance="Transparent" Padding="5,4" Margin="1,0,0,0"
                                           Height="26" MinWidth="0"
                                           Command="{Binding PauseResumeCommand}"
                                           ToolTip="Resume"
                                           Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}">
                                    <ui:SymbolIcon Symbol="Play24" FontSize="13" Foreground="White"/>
                                </ui:Button>

                                <!-- Cancel — Downloading / Paused / Queued -->
                                <ui:Button Appearance="Transparent" Padding="5,4" Margin="1,0,0,0"
                                           Height="26" MinWidth="0"
                                           Command="{Binding CancelCommand}"
                                           ToolTip="Cancel"
                                           Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}">
                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="12"
                                                   Foreground="#FFAAAAAA"/>
                                </ui:Button>

                                <!-- Play — Completed -->
                                <ui:Button Appearance="Transparent" Padding="5,4" Margin="1,0,0,0"
                                           Height="26" MinWidth="0"
                                           Command="{Binding OpenFileCommand}"
                                           ToolTip="Play / Open file"
                                           Visibility="{Binding CanOpen, Converter={StaticResource BoolToVis}}">
                                    <ui:SymbolIcon Symbol="Play24" FontSize="13" Foreground="#FF7EC8A0"/>
                                </ui:Button>

                                <!-- Show in folder — Completed -->
                                <ui:Button Appearance="Transparent" Padding="5,4" Margin="1,0,0,0"
                                           Height="26" MinWidth="0"
                                           Command="{Binding ShowInFolderCommand}"
                                           ToolTip="Show in folder"
                                           Visibility="{Binding CanOpen, Converter={StaticResource BoolToVis}}">
                                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" Foreground="White"/>
                                </ui:Button>

                                <!-- Retry — Failed / Cancelled -->
                                <ui:Button Appearance="Transparent" Padding="5,4" Margin="1,0,0,0"
                                           Height="26" MinWidth="0"
                                           Command="{Binding RetryCommand}"
                                           ToolTip="Retry"
                                           Visibility="{Binding CanRetry, Converter={StaticResource BoolToVis}}">
                                    <ui:SymbolIcon Symbol="ArrowCounterclockwise24" FontSize="13"
                                                   Foreground="#FFAAAAAA"/>
                                </ui:Button>

                            </StackPanel>
                        </Grid>

                        <!-- ── Row 2: source URL + size ── -->
                        <TextBlock Grid.Row="2" FontSize="12" Opacity="0.50"
                                   Foreground="White" TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding SourceUrl, Mode=OneWay}"/>
                            <Run Text=" • "/>
                            <Run Text="{Binding SizeText, Mode=OneWay}"/>
                        </TextBlock>

                        <!-- ── Row 4: progress bar ── -->
                        <ProgressBar Grid.Row="4"
                                     Value="{Binding Progress, Mode=OneWay}"
                                     IsIndeterminate="{Binding IsIndeterminate, Mode=OneWay}"
                                     Minimum="0" Maximum="1"
                                     Height="4"/>

                        <!-- ── Row 6: percent + speed | graph + ETA ── -->
                        <Grid Grid.Row="6"
                              Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Percentage: only show when we know total bytes -->
                                <TextBlock FontSize="11" Opacity="0.55" Foreground="White"
                                           Visibility="{Binding IsIndeterminate, Converter={StaticResource InverseBoolToVis}}">
                                    <TextBlock.Text>
                                        <Binding Path="Progress" Converter="{StaticResource PercentConv}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                                <!-- Speed / "Connecting…" -->
                                <TextBlock Text="{Binding SpeedText}"
                                           FontSize="11" Opacity="0.75" Foreground="White"
                                           Margin="10,0,0,0"/>
                            </StackPanel>
                            <!-- Speed graph + ETA — right-aligned -->
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <controls:SpeedGraph Speed="{Binding SpeedBytesPerSecond}"
                                                     Width="88" Height="22"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding EtaText}"
                                           FontSize="11" Opacity="0.50" Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- ── Row 7: error message (visible only when Failed) ── -->
                        <TextBlock Grid.Row="7"
                                   Text="{Binding ErrorMessage}"
                                   FontSize="11" Foreground="#FFCF6679"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding IsFailed, Converter={StaticResource BoolToVis}}"/>

                    </Grid>
                </Border>

                <!-- Accent glow overlay — opacity animated by DataTemplate.Triggers above -->
                <Border x:Name="GlowBorder"
                        CornerRadius="10"
                        BorderBrush="{DynamicResource SystemAccentColorBrush}"
                        BorderThickness="1.5"
                        Opacity="0"
                        IsHitTestVisible="False"/>

            </Grid>
        </DataTemplate>

    </Page.Resources>

    <!-- ═════════════════════════════════════════════════════════════
         Page layout
         ═════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header bar ── -->
        <!-- Opacity="0" prevents 1-frame flash before the entrance animation starts -->
        <Border Grid.Row="0" Opacity="0" Padding="28,22,28,16"
                Background="#14FFFFFF"
                BorderBrush="#0CFFFFFF" BorderThickness="0,0,0,1">
            <Border.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Downloads" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                    <Border Margin="10,0,0,0" Padding="8,2,8,2" CornerRadius="10"
                            Background="{DynamicResource SystemAccentColorBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Downloads.Count}" FontSize="11"
                                   Foreground="White" FontWeight="Medium"/>
                    </Border>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Appearance="Secondary" Command="{Binding BatchAddCommand}"
                               Padding="14,8" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="AddCircle24" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Batch Add" FontSize="13"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button Appearance="Primary" Command="{Binding AddDownloadCommand}"
                               Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Add24" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Add Download" FontSize="13"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Content area ── -->
        <Grid Grid.Row="1">

            <!-- Skeleton loading (visible while IsLoading) -->
            <ScrollViewer Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto" Padding="28,20,28,20">
                <StackPanel>
                    <!-- Three skeleton cards -->
                    <Border CornerRadius="10" Padding="18,14" Margin="0,0,0,10" Background="#24FFFFFF">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <controls:SkeletonBlock Height="16" Width="220"
                                                        HorizontalAlignment="Left"/>
                                <controls:SkeletonBlock Height="22" Width="88"
                                                        HorizontalAlignment="Right"/>
                            </Grid>
                            <controls:SkeletonBlock Height="12" Width="300"
                                                    HorizontalAlignment="Left" Margin="0,0,0,14"/>
                            <controls:SkeletonBlock Height="4" Margin="0,0,0,8"/>
                            <Grid>
                                <controls:SkeletonBlock Height="11" Width="60" HorizontalAlignment="Left"/>
                                <controls:SkeletonBlock Height="11" Width="50" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="10" Padding="18,14" Margin="0,0,0,10" Background="#1EFFFFFF">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <controls:SkeletonBlock Height="16" Width="180"
                                                        HorizontalAlignment="Left"/>
                                <controls:SkeletonBlock Height="22" Width="88"
                                                        HorizontalAlignment="Right"/>
                            </Grid>
                            <controls:SkeletonBlock Height="12" Width="260"
                                                    HorizontalAlignment="Left" Margin="0,0,0,14"/>
                            <controls:SkeletonBlock Height="4" Margin="0,0,0,8"/>
                            <Grid>
                                <controls:SkeletonBlock Height="11" Width="70" HorizontalAlignment="Left"/>
                                <controls:SkeletonBlock Height="11" Width="45" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="10" Padding="18,14" Background="#18FFFFFF">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <controls:SkeletonBlock Height="16" Width="250"
                                                        HorizontalAlignment="Left"/>
                                <controls:SkeletonBlock Height="22" Width="88"
                                                        HorizontalAlignment="Right"/>
                            </Grid>
                            <controls:SkeletonBlock Height="12" Width="320"
                                                    HorizontalAlignment="Left" Margin="0,0,0,14"/>
                            <controls:SkeletonBlock Height="4" Margin="0,0,0,8"/>
                            <Grid>
                                <controls:SkeletonBlock Height="11" Width="55" HorizontalAlignment="Left"/>
                                <controls:SkeletonBlock Height="11" Width="60" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Empty state — Opacity="0" prevents flash before entrance animation -->
            <StackPanel Opacity="0"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.4"/>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                    From="20" To="0" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <QuarticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </StackPanel.Triggers>
                <StackPanel.RenderTransform>
                    <TranslateTransform/>
                </StackPanel.RenderTransform>
                <ui:SymbolIcon Symbol="ArrowDownload48" FontSize="52"
                               Foreground="White" Opacity="0.18"
                               HorizontalAlignment="Center"/>
                <TextBlock Text="No downloads yet"
                           FontSize="18" FontWeight="Medium"
                           Foreground="White" Opacity="0.45"
                           HorizontalAlignment="Center" Margin="0,14,0,6"/>
                <TextBlock Text="Click &quot;Add Download&quot; to get started"
                           FontSize="13" Foreground="White" Opacity="0.30"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Downloads list — CanContentScroll=True enables item-based virtualisation -->
            <ScrollViewer Visibility="{Binding HasDownloads, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto" Padding="28,20,28,20"
                          ScrollViewer.CanContentScroll="True">
                <ItemsControl ItemsSource="{Binding Downloads}"
                              ItemTemplate="{StaticResource CardTemplate}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Grid>

</Page>
