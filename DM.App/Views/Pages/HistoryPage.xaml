<Page x:Class="DM.App.Views.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:DM.App.ViewModels"
      xmlns:conv="clr-namespace:DM.App.Converters"
      Background="Transparent">

    <Page.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,22,28,16"
                Background="#14FFFFFF"
                BorderBrush="#0CFFFFFF" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="History" FontSize="22" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:TextBox x:Name="SearchBox" Width="200" Margin="0,0,10,0"
                                PlaceholderText="Search history…"
                                TextChanged="Search_TextChanged"/>
                    <ui:Button Appearance="Secondary" Padding="14,8"
                               Click="ClearAll_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Delete24" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Clear All" FontSize="13"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">

            <!-- Empty state -->
            <StackPanel Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.45">
                <ui:SymbolIcon Symbol="History24" FontSize="52"
                               Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="No download history" FontSize="18" FontWeight="Medium"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,14,0,6"/>
                <TextBlock Text="Completed downloads will appear here"
                           FontSize="13" Foreground="White"
                           HorizontalAlignment="Center" Opacity="0.65"/>
            </StackPanel>

            <!-- List -->
            <ScrollViewer Visibility="{Binding IsEmpty, Converter={StaticResource InvBoolToVis}}"
                          VerticalScrollBarVisibility="Auto" Padding="28,20,28,20">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:HistoryItemViewModel}">
                            <Border CornerRadius="10" Padding="16,12" Margin="0,0,0,8"
                                    Background="#28FFFFFF">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Document24" FontSize="15"
                                                           Foreground="White" Opacity="0.60"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding FileName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="White"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="White" Opacity="0.50"
                                                   Margin="0,4,0,0" TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding Url, Mode=OneWay}"/>
                                            <Run Text=" • "/>
                                            <Run Text="{Binding SizeText, Mode=OneWay}"/>
                                            <Run Text=" • "/>
                                            <Run Text="{Binding TimeAgoText, Mode=OneWay}"/>
                                        </TextBlock>
                                        <!-- Checksum row -->
                                        <TextBlock Margin="0,3,0,0" FontSize="11"
                                                   Text="{Binding ChecksumSummary}"
                                                   Visibility="{Binding HasChecksum, Converter={StaticResource BoolToVis}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FF4CAF50"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ChecksumOk}" Value="False">
                                                            <Setter Property="Foreground" Value="#FFF44336"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <ui:Button Appearance="Secondary" Padding="12,6" Margin="0,0,6,0"
                                                   Command="{Binding DataContext.ReDownloadCommand,
                                                       RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"
                                                   ToolTip="Re-download">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="13" Margin="0,0,5,0"/>
                                                <TextBlock Text="Re-download" FontSize="12"/>
                                            </StackPanel>
                                        </ui:Button>
                                        <ui:Button Appearance="Transparent" Padding="6,6"
                                                   Command="{Binding DataContext.RemoveCommand,
                                                       RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"
                                                   ToolTip="Remove from history">
                                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="12"
                                                           Foreground="#FFAAAAAA"/>
                                        </ui:Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Grid>
</Page>
