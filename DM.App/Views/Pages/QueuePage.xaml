<Page x:Class="DM.App.Views.Pages.QueuePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:DM.App.ViewModels"
      xmlns:conv="clr-namespace:DM.App.Converters"
      Background="Transparent">

    <Page.Resources>
        <conv:BoolToVisibilityConverter          x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter   x:Key="InvBoolToVis"/>
        <conv:IntToInverseVisibilityConverter    x:Key="IntInvToVis"/>
        <conv:ProgressToPercentConverter         x:Key="PercentConv"/>
        <conv:PriorityToColorConverter           x:Key="PriorityColor"/>

        <Style x:Key="PriorityMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Opacity="0" Padding="28,22,28,16"
                Background="#14FFFFFF" BorderBrush="#0CFFFFFF" BorderThickness="0,0,0,1">
            <Border.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Queue" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                    <Border Margin="10,0,0,0" Padding="8,2,8,2" CornerRadius="10"
                            Background="{DynamicResource SystemAccentColorBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Items.Count}" FontSize="11"
                                   Foreground="White" FontWeight="Medium"/>
                    </Border>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Appearance="Secondary" Command="{Binding PauseAllCommand}" Padding="12,7" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Pause24" FontSize="13" Margin="0,0,5,0"/>
                            <TextBlock Text="Pause All" FontSize="13"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button Appearance="Primary" Command="{Binding ResumeAllCommand}" Padding="12,7">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Play24" FontSize="13" Margin="0,0,5,0"/>
                            <TextBlock Text="Resume All" FontSize="13"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Queue list (full width) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
            <StackPanel>
                <!-- Empty state -->
                <TextBlock Text="No active downloads in queue"
                           FontSize="14" Foreground="White" Opacity="0.35"
                           HorizontalAlignment="Center" Margin="0,60,0,0"
                           Visibility="{Binding Items.Count, Converter={StaticResource IntInvToVis}}"/>

                <!-- Queue items -->
                <ItemsControl x:Name="QueueList"
                              ItemsSource="{Binding Items}"
                              AllowDrop="True"
                              Drop="QueueList_Drop"
                              DragOver="QueueList_DragOver">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:QueueItemViewModel}">
                            <Border CornerRadius="9" Padding="14,11" Margin="0,0,0,8"
                                    Background="#28FFFFFF"
                                    AllowDrop="True"
                                    MouseMove="QueueItem_MouseMove"
                                    Tag="{Binding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Drag handle -->
                                    <TextBlock Grid.Column="0"
                                               Text="&#8801;" FontSize="16"
                                               Foreground="White" Opacity="0.30"
                                               VerticalAlignment="Center"
                                               Cursor="SizeAll"
                                               MouseLeftButtonDown="DragHandle_MouseDown"
                                               Tag="{Binding}"/>

                                    <!-- Content -->
                                    <StackPanel Grid.Column="1">
                                        <Grid Margin="0,0,0,5">
                                            <Border HorizontalAlignment="Left"
                                                    Padding="6,2" CornerRadius="5"
                                                    Background="{Binding Priority, Converter={StaticResource PriorityColor}}">
                                                <TextBlock Text="{Binding Priority}"
                                                           FontSize="10" FontWeight="Medium"
                                                           Foreground="White"/>
                                            </Border>
                                            <TextBlock HorizontalAlignment="Right"
                                                       Text="{Binding Status}"
                                                       FontSize="11" Foreground="White" Opacity="0.45"
                                                       VerticalAlignment="Center"/>
                                        </Grid>

                                        <TextBlock Text="{Binding FileName}"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="White" TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,4"/>

                                        <ProgressBar Value="{Binding Progress, Mode=OneWay}" Minimum="0" Maximum="1"
                                                     Height="3" Margin="0,0,0,4"/>

                                        <Grid>
                                            <TextBlock Text="{Binding SizeText}"
                                                       FontSize="11" Foreground="White" Opacity="0.50"/>
                                            <TextBlock Text="{Binding SpeedText}"
                                                       FontSize="11" Foreground="White" Opacity="0.70"
                                                       HorizontalAlignment="Right"
                                                       Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Context actions -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                VerticalAlignment="Top" Margin="8,0,0,0">
                                        <ui:Button Appearance="Transparent" Padding="4,3"
                                                   Height="24" MinWidth="0"
                                                   Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"
                                                   ToolTip="Move up">
                                            <ui:SymbolIcon Symbol="ChevronUp24" FontSize="11" Foreground="White" Opacity="0.6"/>
                                        </ui:Button>
                                        <ui:Button Appearance="Transparent" Padding="4,3"
                                                   Height="24" MinWidth="0"
                                                   Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"
                                                   ToolTip="Move down">
                                            <ui:SymbolIcon Symbol="ChevronDown24" FontSize="11" Foreground="White" Opacity="0.6"/>
                                        </ui:Button>
                                        <ui:Button Appearance="Transparent" Padding="4,3"
                                                   Height="24" MinWidth="0"
                                                   ToolTip="Set priority"
                                                   Click="PriorityBtn_Click"
                                                   Tag="{Binding}">
                                            <ui:SymbolIcon Symbol="ArrowSort24" FontSize="11" Foreground="White" Opacity="0.6"/>
                                        </ui:Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
