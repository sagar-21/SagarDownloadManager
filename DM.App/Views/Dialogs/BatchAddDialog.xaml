<ui:FluentWindow x:Class="DM.App.Views.Dialogs.BatchAddDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Batch Add Downloads"
        Width="520" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <TextBlock Text="Paste URLs (one per line)" FontSize="12"
                       Foreground="White" Opacity="0.65"/>
            <TextBlock x:Name="CountLabel" HorizontalAlignment="Right"
                       FontSize="11" Foreground="White" Opacity="0.45"/>
        </Grid>

        <!-- URL textarea -->
        <Border Grid.Row="2" CornerRadius="6" BorderBrush="#30FFFFFF" BorderThickness="1">
            <ui:TextBox x:Name="UrlsBox"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        PlaceholderText="https://example.com/file1.zip
https://example.com/file2.iso
https://example.com/file3.pkg"
                        Background="Transparent"
                        BorderThickness="0"
                        TextChanged="UrlsBox_TextChanged"/>
        </Border>

        <!-- Save to -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Save to" FontSize="12" Foreground="White" Opacity="0.65" Margin="0,0,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="FolderBox" Grid.Column="0"
                            PlaceholderText="Choose destination folder…"/>
                <ui:Button Grid.Column="2" Appearance="Secondary"
                           Padding="12,0" Click="Browse_Click">
                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14"/>
                </ui:Button>
            </Grid>
        </StackPanel>

        <!-- After download -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="After each download" FontSize="12"
                       Foreground="White" Opacity="0.65" Margin="0,0,0,6"/>
            <ComboBox x:Name="ActionBox" SelectedIndex="0">
                <ComboBoxItem>None</ComboBoxItem>
                <ComboBoxItem>Show notification</ComboBoxItem>
                <ComboBoxItem>Open folder</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Appearance="Secondary" Margin="0,0,8,0" Padding="20,8"
                       Click="Cancel_Click">Cancel</ui:Button>
            <ui:Button x:Name="OkBtn" Appearance="Primary" Padding="20,8"
                       IsDefault="True" Click="Ok_Click">Queue Downloads</ui:Button>
        </StackPanel>
    </Grid>

</ui:FluentWindow>
