<ui:FluentWindow x:Class="DM.App.Views.Dialogs.PlaylistSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:DM.App.Views.Dialogs"
        Title="Select Videos to Download"
        Width="560" Height="580"
        MinWidth="440" MinHeight="380"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid Margin="24,24,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>   <!-- toolbar -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>      <!-- list -->
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>   <!-- footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="HeaderText"
                       FontSize="15" FontWeight="SemiBold" Foreground="White"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="SubtitleText"
                       FontSize="11" Foreground="White" Opacity="0.50"
                       Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Toolbar: Select All / Deselect All + selected count -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0" Appearance="Secondary" Padding="10,4" FontSize="12"
                       Content="Select All" Click="SelectAll_Click"/>
            <ui:Button Grid.Column="2" Appearance="Secondary" Padding="10,4" FontSize="12"
                       Content="Deselect All" Click="DeselectAll_Click"/>
            <TextBlock Grid.Column="4" x:Name="CountText"
                       FontSize="11" Foreground="White" Opacity="0.55"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Divider -->
        <Border Grid.Row="3" Height="1" Background="#1AFFFFFF" VerticalAlignment="Bottom"/>

        <!-- Video list -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Padding="0,4">
            <ItemsControl x:Name="ItemsList"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:PlaylistItemVm}">
                        <Border Padding="6,4" CornerRadius="4" Background="Transparent"
                                Cursor="Hand" MouseLeftButtonDown="ItemRow_MouseDown">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#0FFFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="54"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"
                                          Checked="Checkbox_Changed"
                                          Unchecked="Checkbox_Changed"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding IndexDisplay}"
                                           FontSize="12" Foreground="White" Opacity="0.30"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Entry.Title}"
                                           FontSize="12" Foreground="White"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding DurationText}"
                                           FontSize="11" Foreground="White" Opacity="0.40"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="1" Appearance="Secondary" Padding="20,8"
                       Content="Cancel" Click="Cancel_Click"/>
            <ui:Button Grid.Column="3" x:Name="DownloadBtn" Appearance="Primary" Padding="20,8"
                       IsDefault="True" Click="Download_Click">Download selected</ui:Button>
        </Grid>
    </Grid>

</ui:FluentWindow>
