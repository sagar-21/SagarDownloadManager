<Window x:Class="DM.App.Views.Dialogs.LicenseAlertDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Notice"
        Width="440" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True">

    <Border CornerRadius="12" Background="#0F172A"
            BorderBrush="#1E293B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Accent strip (color set in code-behind) -->
            <Border x:Name="AccentBar" Grid.Row="0" CornerRadius="12,12,0,0"/>

            <!-- Icon + Title -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        Margin="26,22,26,0"
                        MouseLeftButtonDown="Window_MouseDown">
                <Border x:Name="IconBorder" Width="48" Height="48"
                        CornerRadius="24" Margin="0,0,16,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="IconText" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold"
                               Foreground="#F8FAFC"/>
                    <TextBlock Text="Sagar Download Manager" FontSize="11"
                               Foreground="#475569" Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Message -->
            <TextBlock x:Name="MessageText" Grid.Row="2"
                       Margin="26,16,26,0"
                       Foreground="#94A3B8" FontSize="13"
                       LineHeight="22" TextWrapping="Wrap"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Margin="26,16,26,26">

                <!-- ── Try Again row (expired only) ── -->
                <Button x:Name="TryAgainBtn" Margin="0,0,0,10"
                        Visibility="Collapsed" HorizontalAlignment="Stretch"
                        Click="TryAgain_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background"      Value="#16A34A"/>
                            <Setter Property="Foreground"      Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Height"          Value="38"/>
                            <Setter Property="Padding"         Value="20,0"/>
                            <Setter Property="FontSize"        Value="13"/>
                            <Setter Property="Cursor"          Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#15803D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#8635;" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Already extended on the website? Try Again" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- ── Expired-only action row ── -->
                <StackPanel x:Name="ExpiredActionRow" Orientation="Horizontal"
                            Margin="0,0,0,10" Visibility="Collapsed">
                    <!-- Enter New Key -->
                    <Button x:Name="NewKeyBtn" Margin="0,0,8,0"
                            Click="NewKey_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="#F97316"/>
                                <Setter Property="Foreground"   Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Height"       Value="38"/>
                                <Setter Property="Padding"      Value="20,0"/>
                                <Setter Property="FontSize"     Value="13"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#EA6A00"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#128273;" FontSize="14" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Enter New Key" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Request Extension -->
                    <Button x:Name="RequestExtBtn"
                            Click="RequestExtension_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="#1D4ED8"/>
                                <Setter Property="Foreground"   Value="#E0ECFF"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Height"       Value="38"/>
                                <Setter Property="Padding"      Value="20,0"/>
                                <Setter Property="FontSize"     Value="13"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2563EB"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#8599;" FontSize="15" FontWeight="Bold"
                                       Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Request Extension" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- ── Standard bottom row (all types) ── -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="LinkedInBtn"
                            Margin="0,0,10,0"
                            Click="LinkedIn_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="#1D4ED8"/>
                                <Setter Property="Foreground"   Value="#E0ECFF"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Height"       Value="36"/>
                                <Setter Property="Padding"      Value="18,0"/>
                                <Setter Property="FontSize"     Value="13"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="7"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2563EB"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#1E40AF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="CloseBtn"
                            Content="Close Application"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="#1E293B"/>
                                <Setter Property="Foreground"   Value="#94A3B8"/>
                                <Setter Property="BorderBrush"  Value="#334155"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Height"       Value="36"/>
                                <Setter Property="Padding"      Value="18,0"/>
                                <Setter Property="FontSize"     Value="13"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="7"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#263045"/>
                                                    <Setter Property="Foreground" Value="#CBD5E1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
