<ui:FluentWindow x:Class="DM.App.Views.Dialogs.LicensesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Open-Source Licenses"
        Width="900" Height="580"
        MinWidth="640" MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="#FF7EC8E3"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin"  Value="6,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" CornerRadius="6" Background="Transparent"
                                Padding="14,9">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#14FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left sidebar ───────────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Background="#10FFFFFF"
                BorderBrush="#0EFFFFFF"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="COMPONENTS"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="White" Opacity="0.40"
                           Padding="16,14,16,8"/>
                <ListBox x:Name="ComponentList"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="ComponentList_SelectionChanged"
                         ItemContainerStyle="{StaticResource NavItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="White" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Spdx}"
                                           FontSize="11" Foreground="White"
                                           Opacity="0.50" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── Right content ─────────────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Component header -->
            <Border Grid.Row="0"
                    Padding="24,14,24,14"
                    BorderBrush="#0CFFFFFF"
                    BorderThickness="0,0,0,1">
                <StackPanel>
                    <!-- Name + badges row -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="NameText"
                                   FontSize="19" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <Border CornerRadius="4" Background="#20FFFFFF"
                                Padding="8,3" Margin="10,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="VersionText"
                                       FontSize="11" Foreground="White" Opacity="0.65"/>
                        </Border>
                        <Border x:Name="SpdxBadge"
                                CornerRadius="4" Background="#CC1A7C3E"
                                Padding="8,3" Margin="6,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="SpdxText"
                                       FontSize="11" Foreground="White"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Links row -->
                    <WrapPanel Margin="0,9,0,0">
                        <TextBlock FontSize="12" Foreground="White" Opacity="0.50"
                                   VerticalAlignment="Center" Text="Homepage: "/>
                        <TextBlock FontSize="12" VerticalAlignment="Center">
                            <Hyperlink x:Name="HomepageLink"
                                       RequestNavigate="Link_RequestNavigate">
                                <Run x:Name="HomepageLinkRun"/>
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="White" Opacity="0.40"
                                   VerticalAlignment="Center" Margin="10,0" Text="·"/>
                        <TextBlock FontSize="12" Foreground="White" Opacity="0.50"
                                   VerticalAlignment="Center" Text="License: "/>
                        <TextBlock FontSize="12" VerticalAlignment="Center">
                            <Hyperlink x:Name="LicenseFileLink"
                                       RequestNavigate="Link_RequestNavigate">
                                <Run x:Name="LicenseFileLinkRun"/>
                            </Hyperlink>
                        </TextBlock>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ffmpeg LGPL attribution notice (hidden unless ffmpeg selected) -->
            <Border x:Name="FfmpegNotice"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    Background="#18D48A00"
                    BorderBrush="#30E09020"
                    BorderThickness="0,0,0,1"
                    Padding="24,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <ui:SymbolIcon Symbol="ShieldCheckmark24"
                                       FontSize="13" Foreground="#FFE09020"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="LGPL Compliance"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#FFE09020" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock FontSize="12" Foreground="White" Opacity="0.80"
                               TextWrapping="Wrap" LineHeight="18">
                        This app bundles the
                        <Run FontWeight="SemiBold">LGPL build</Run>
                        of ffmpeg (not the GPL build). ffmpeg is invoked as a
                        <Run FontWeight="SemiBold">separate child process</Run>
                        via Process.Start() and is not statically or dynamically linked into this app.
                        Users may replace Tools\ffmpeg.exe with any LGPL-compatible build.
                        Source code (required by LGPL §6):
                        <Hyperlink x:Name="FfmpegSourceLink"
                                   RequestNavigate="Link_RequestNavigate">https://ffmpeg.org/download.html</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- License text scroll area -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,16,20,24">
                <TextBlock x:Name="LicenseBodyText"
                           FontFamily="Consolas, Courier New, monospace"
                           FontSize="11.5"
                           Foreground="White" Opacity="0.75"
                           TextWrapping="Wrap"
                           LineHeight="18"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>
