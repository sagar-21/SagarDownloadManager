<ui:FluentWindow x:Class="DM.App.Views.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Activate Download Manager"
        Width="460" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid Margin="36,28,36,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- icon + title -->
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>  <!-- key input -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- activate button -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- status message -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- fingerprint -->
        </Grid.RowDefinitions>

        <!-- Header: icon + title -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <Border Width="56" Height="56" CornerRadius="14"
                    Background="{DynamicResource SystemAccentColorBrush}"
                    Margin="0,0,0,14" HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="Key24" FontSize="26" Foreground="White"/>
            </Border>
            <TextBlock Text="Activate Download Manager"
                       FontSize="18" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Enter your license key to unlock all features."
                       FontSize="13" Opacity="0.55" Margin="0,5,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- License key input -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="LICENSE KEY" FontSize="11" Opacity="0.55"
                       Margin="0,0,0,6" FontWeight="Medium"/>
            <ui:TextBox x:Name="KeyBox"
                        PlaceholderText="DM25-XXXX-XXXX-XXXX"
                        Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                        FontFamily="Cascadia Code, Consolas, monospace"
                        FontSize="16"
                        MaxLength="19"
                        KeyDown="KeyBox_KeyDown"/>
        </StackPanel>

        <!-- Activate button — enabled/disabled by ActivateCommand.CanExecute -->
        <ui:Button Grid.Row="4"
                   Content="Activate"
                   Appearance="Primary"
                   HorizontalAlignment="Stretch"
                   Height="40"
                   FontSize="14"
                   Command="{Binding ActivateCommand}"/>

        <!-- Status message area -->
        <Border Grid.Row="6" CornerRadius="7" Padding="12,9"
                Visibility="{Binding ShowStatus, Converter={StaticResource BoolToVis}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasError}" Value="True">
                            <Setter Property="Background"   Value="#1AEF4444"/>
                            <Setter Property="BorderBrush"  Value="#30EF4444"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                            <Setter Property="Background"   Value="#1A22C55E"/>
                            <Setter Property="BorderBrush"  Value="#3022C55E"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="15" Margin="0,0,6,0"
                               Foreground="#EF4444"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
                <ui:SymbolIcon Symbol="Checkmark24" FontSize="15" Margin="0,0,6,0"
                               Foreground="#22C55E"
                               Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Machine fingerprint (for support) -->
        <StackPanel Grid.Row="8">
            <Separator Opacity="0.15" Margin="0,0,0,10"/>
            <TextBlock Text="MACHINE ID" FontSize="10" Opacity="0.40"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding MachineFingerprint}"
                       FontFamily="Cascadia Code, Consolas, monospace"
                       FontSize="11" Opacity="0.45"
                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
