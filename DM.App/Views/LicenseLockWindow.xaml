<ui:FluentWindow x:Class="DM.App.Views.LicenseLockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="License Issue"
        Width="460" Height="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Topmost="True">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid Margin="40,32,40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status icon -->
        <Border Grid.Row="0" Width="56" Height="56" CornerRadius="14"
                HorizontalAlignment="Center" Margin="0,0,0,14">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#1AEF4444"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSuspended}" Value="True">
                            <Setter Property="Background" Value="#1AF59E0B"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsExpiredOrOffline}" Value="True">
                            <Setter Property="Background" Value="#1A6B7280"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ui:SymbolIcon FontSize="26">
                <ui:SymbolIcon.Style>
                    <Style TargetType="ui:SymbolIcon">
                        <Setter Property="Symbol"     Value="ProhibitedMultiple24"/>
                        <Setter Property="Foreground" Value="#EF4444"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuspended}" Value="True">
                                <Setter Property="Symbol"     Value="PauseCircle24"/>
                                <Setter Property="Foreground" Value="#F59E0B"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsExpiredOrOffline}" Value="True">
                                <Setter Property="Symbol"     Value="ClockDismiss24"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:SymbolIcon.Style>
            </ui:SymbolIcon>
        </Border>

        <!-- Title -->
        <TextBlock Grid.Row="1" Text="{Binding Title}"
                   FontSize="19" FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>

        <!-- Message -->
        <TextBlock Grid.Row="3" Text="{Binding Message}"
                   FontSize="13" Opacity="0.60"
                   TextWrapping="Wrap" TextAlignment="Center"
                   HorizontalAlignment="Center" MaxWidth="360"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" HorizontalAlignment="Center">

            <!-- Try Again (shown for suspended / offline / grace-expired) -->
            <ui:Button Appearance="Primary" Width="220" Height="38"
                       Command="{Binding RetryCommand}"
                       Visibility="{Binding CanRetry, Converter={StaticResource BoolToVis}}"
                       Margin="0,0,0,8">
                <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Setter Property="Content" Value="Try Again"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRetrying}" Value="True">
                                <Setter Property="Content" Value="Checking…"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>

            <ui:Button Content="Use a Different License Key"
                       Appearance="Secondary"
                       Width="220" Height="36"
                       Command="{Binding ChangeKeyCommand}"
                       Margin="0,0,0,8"/>

            <TextBlock HorizontalAlignment="Center" Margin="0,6,0,0">
                <Hyperlink NavigateUri="mailto:support@yourapp.com"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    Contact support →
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
