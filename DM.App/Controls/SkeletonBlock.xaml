<UserControl x:Class="DM.App.Controls.SkeletonBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="6" ClipToBounds="True">
        <Border.Background>
            <SolidColorBrush Color="#22FFFFFF"/>
        </Border.Background>

        <!--
            Shimmer in relative gradient coordinates (0–1 = element width) so it
            covers the full element at any pixel size without hardcoded pixel offsets.
            SL/SC/SR travel from off-screen left to off-screen right; the extra travel
            past 1.0 creates a natural ~0.9 s pause before the next sweep without
            KeyFrames. Linear motion (no easing) matches Fluent shimmer convention.
        -->
        <Rectangle Stretch="Fill">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop x:Name="SL" Color="Transparent" Offset="-0.25"/>
                    <GradientStop x:Name="SC" Color="#55FFFFFF"   Offset="0.0"/>
                    <GradientStop x:Name="SR" Color="Transparent" Offset="0.25"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="SL"
                                             Storyboard.TargetProperty="Offset"
                                             From="-0.25" To="1.0"  Duration="0:0:2.2"/>
                            <DoubleAnimation Storyboard.TargetName="SC"
                                             Storyboard.TargetProperty="Offset"
                                             From="0.0"   To="1.25" Duration="0:0:2.2"/>
                            <DoubleAnimation Storyboard.TargetName="SR"
                                             Storyboard.TargetProperty="Offset"
                                             From="0.25"  To="1.5"  Duration="0:0:2.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>
    </Border>
</UserControl>
