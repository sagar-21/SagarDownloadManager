@page
@model LoginModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Sign in — LicenseServer</title>
  <style>
    :root {
      --bg: #0D1117; --surf: #161C28; --border: rgba(255,255,255,0.065);
      --accent: #00D4AA; --text: #E2E8F0; --text-2: rgba(226,232,240,0.55);
      --danger: #EF4444; --danger-bg: rgba(239,68,68,0.12);
    }
    *, *::before, *::after { box-sizing: border-box; }
    body {
      background: var(--bg); color: var(--text); margin: 0;
      font-family: -apple-system,'Segoe UI',system-ui,sans-serif; font-size: 14px;
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
    }
    .box {
      width: 380px; background: var(--surf); border: 1px solid var(--border);
      border-radius: 12px; padding: 36px 32px;
    }
    .brand {
      display: flex; align-items: center; gap: 10px; margin-bottom: 28px;
    }
    .brand-icon {
      width: 34px; height: 34px; border-radius: 8px;
      background: rgba(0,212,170,0.12); border: 1px solid rgba(0,212,170,0.25);
      display: flex; align-items: center; justify-content: center; font-size: 16px;
    }
    .brand-name { font-size: 16px; font-weight: 600; }
    .brand-sub  { font-size: 11px; color: var(--text-2); margin-top: 1px; }
    h1 { font-size: 18px; font-weight: 600; margin-bottom: 6px; }
    .subtitle { font-size: 13px; color: var(--text-2); margin-bottom: 24px; }
    label {
      display: block; font-size: 11px; letter-spacing: .06em; text-transform: uppercase;
      color: rgba(226,232,240,0.35); margin-bottom: 6px; font-weight: 500;
    }
    input[type=text], input[type=password] {
      width: 100%; background: rgba(255,255,255,0.04); border: 1px solid var(--border);
      border-radius: 7px; padding: 10px 12px; color: var(--text); font-size: 13.5px;
      font-family: inherit; outline: none; margin-bottom: 16px;
      transition: border-color .13s;
    }
    input:focus { border-color: rgba(0,212,170,0.35); }
    input::placeholder { color: rgba(226,232,240,0.25); }
    .btn {
      width: 100%; padding: 11px; background: var(--accent); color: #06130F;
      border: none; border-radius: 7px; font-size: 14px; font-weight: 600;
      cursor: pointer; font-family: inherit; transition: opacity .13s;
    }
    .btn:hover { opacity: .88; }
    .err {
      background: var(--danger-bg); color: var(--danger);
      border: 1px solid rgba(239,68,68,.2); border-radius: 7px;
      padding: 10px 14px; font-size: 13px; margin-bottom: 16px;
    }
  </style>
</head>
<body>
  <div class="box">
    <div class="brand">
      <div class="brand-icon">🔑</div>
      <div>
        <div class="brand-name">LicenseServer</div>
        <div class="brand-sub">Admin Panel</div>
      </div>
    </div>

    <h1>Sign in</h1>
    <p class="subtitle">Enter your admin credentials to continue.</p>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
      <div class="err">@Model.Error</div>
    }

    <form method="post">
      @Html.AntiForgeryToken()
      <label for="Username">Username</label>
      <input type="text" id="Username" name="Username" placeholder="admin" autocomplete="username"/>
      <label for="Password">Password</label>
      <input type="password" id="Password" name="Password" placeholder="••••••••••••" autocomplete="current-password"/>
      <button type="submit" class="btn">Sign in</button>
    </form>
  </div>
</body>
</html>
