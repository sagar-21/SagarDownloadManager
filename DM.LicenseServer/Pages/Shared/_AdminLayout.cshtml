<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>@(ViewData["Title"] ?? "Admin") — LicenseServer</title>
  <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous"/>
  <style>
    :root {
      --bg:          #0D1117;
      --surf:        #161C28;
      --surf-hi:     #1E2A3A;
      --border:      rgba(255,255,255,0.065);
      --accent:      #00D4AA;
      --accent-dim:  rgba(0,212,170,0.12);
      --text:        #E2E8F0;
      --text-2:      rgba(226,232,240,0.55);
      --text-3:      rgba(226,232,240,0.30);
      --success:     #22C55E;
      --success-bg:  rgba(34,197,94,0.12);
      --warning:     #F59E0B;
      --warning-bg:  rgba(245,158,11,0.12);
      --danger:      #EF4444;
      --danger-bg:   rgba(239,68,68,0.12);
      --info-bg:     rgba(96,165,250,0.12);
      --info:        #60A5FA;
      --mono:        'SF Mono','Cascadia Code','Fira Code','Consolas',monospace;
    }

    *, *::before, *::after { box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system,'Segoe UI',system-ui,sans-serif;
      font-size: 14px;
      display: flex;
      min-height: 100vh;
      margin: 0;
    }

    /* ── Sidebar ── */
    .ls-sidebar {
      width: 220px; min-height: 100vh;
      background: var(--surf); border-right: 1px solid var(--border);
      display: flex; flex-direction: column; flex-shrink: 0;
      position: sticky; top: 0; height: 100vh;
    }

    .ls-brand {
      padding: 18px 20px 16px;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 10px;
    }

    .ls-brand-icon {
      width: 30px; height: 30px; border-radius: 7px;
      background: var(--accent-dim); border: 1px solid rgba(0,212,170,0.25);
      display: flex; align-items: center; justify-content: center; font-size: 14px;
    }

    .ls-brand-name  { font-weight: 600; font-size: 14px; }
    .ls-brand-sub   { font-size: 10px; color: var(--text-3); letter-spacing: .07em; text-transform: uppercase; }

    .ls-nav { flex: 1; padding: 10px 8px; display: flex; flex-direction: column; gap: 2px; }

    .ls-nav-section {
      font-size: 10px; letter-spacing: .07em; text-transform: uppercase;
      color: var(--text-3); padding: 10px 12px 4px; font-weight: 500;
    }

    .ls-nav a {
      display: flex; align-items: center; gap: 9px;
      padding: 8px 12px; border-radius: 7px;
      color: var(--text-2); font-size: 13.5px; text-decoration: none;
      transition: background .12s, color .12s; position: relative;
    }

    .ls-nav a:hover { background: var(--surf-hi); color: var(--text); }

    .ls-nav a.active {
      background: var(--accent-dim); color: var(--accent); font-weight: 500;
    }

    .ls-nav a.active::before {
      content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%);
      width: 3px; height: 18px; background: var(--accent); border-radius: 0 3px 3px 0;
    }

    .ls-footer {
      padding: 12px 8px; border-top: 1px solid var(--border);
    }

    .ls-user {
      display: flex; align-items: center; gap: 9px;
      padding: 8px 12px; border-radius: 7px;
    }

    .ls-avatar {
      width: 28px; height: 28px; border-radius: 50%;
      background: var(--accent-dim); border: 1px solid rgba(0,212,170,0.25);
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 700; color: var(--accent); flex-shrink: 0;
    }

    .ls-user-name { font-size: 12.5px; color: var(--text-2); flex: 1; }

    .ls-logout {
      background: transparent; border: none; cursor: pointer;
      color: var(--text-3); font-size: 13px; padding: 0;
      transition: color .12s;
    }
    .ls-logout:hover { color: var(--danger); }

    /* ── Main ── */
    .ls-main { flex: 1; overflow-x: hidden; }

    .ls-topbar {
      padding: 14px 28px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      background: var(--bg); position: sticky; top: 0; z-index: 100;
    }

    .ls-topbar-title { font-size: 17px; font-weight: 600; letter-spacing: -.02em; }

    .ls-content { padding: 22px 28px; }

    /* ── Cards ── */
    .ls-card {
      background: var(--surf); border: 1px solid var(--border);
      border-radius: 10px; overflow: hidden; margin-bottom: 16px;
    }

    .ls-card-header {
      padding: 12px 18px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
    }

    .ls-card-title { font-size: 13px; font-weight: 600; }

    /* ── Stats ── */
    .ls-stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; margin-bottom: 22px; }

    .ls-stat {
      background: var(--surf); border: 1px solid var(--border);
      border-radius: 10px; padding: 16px 18px;
    }

    .ls-stat-label { font-size: 10px; letter-spacing: .06em; text-transform: uppercase; color: var(--text-3); margin-bottom: 6px; }
    .ls-stat-value { font-size: 28px; font-weight: 700; letter-spacing: -.04em; font-variant-numeric: tabular-nums; }
    .ls-stat-sub   { font-size: 11.5px; color: var(--text-2); margin-top: 3px; }

    /* ── Buttons ── */
    .ls-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 7px 14px; border-radius: 7px; font-size: 13px;
      font-family: inherit; font-weight: 500; cursor: pointer;
      border: none; text-decoration: none; transition: opacity .13s, background .13s;
    }

    .ls-btn-primary  { background: var(--accent); color: #06130F; }
    .ls-btn-primary:hover { opacity: .88; }

    .ls-btn-ghost    { background: transparent; color: var(--text-2); border: 1px solid var(--border); }
    .ls-btn-ghost:hover { background: var(--surf-hi); color: var(--text); }

    .ls-btn-danger   { background: var(--danger-bg); color: var(--danger); border: 1px solid rgba(239,68,68,.25); }
    .ls-btn-danger:hover { background: var(--danger); color: #fff; }

    .ls-btn-warning  { background: var(--warning-bg); color: var(--warning); border: 1px solid rgba(245,158,11,.25); }
    .ls-btn-warning:hover { background: var(--warning); color: #0D1117; }

    .ls-btn-success  { background: var(--success-bg); color: var(--success); border: 1px solid rgba(34,197,94,.25); }
    .ls-btn-success:hover { background: var(--success); color: #06130F; }

    .ls-btn-sm { padding: 4px 10px; font-size: 12px; }

    /* ── Tables ── */
    .ls-table-wrap { overflow-x: auto; }

    .ls-table { width: 100%; border-collapse: collapse; }

    .ls-table th {
      padding: 9px 14px; text-align: left; font-size: 10.5px;
      letter-spacing: .06em; text-transform: uppercase; color: var(--text-3);
      font-weight: 500; border-bottom: 1px solid var(--border); white-space: nowrap;
    }

    .ls-table td {
      padding: 10px 14px; border-bottom: 1px solid rgba(255,255,255,.04);
      font-size: 13px; vertical-align: middle;
    }

    .ls-table tr:last-child td { border-bottom: none; }
    .ls-table tr:hover td { background: rgba(255,255,255,.015); }

    .td-key { font-family: var(--mono); font-size: 12px; color: var(--accent); letter-spacing: .05em; }
    .td-fp  { font-family: var(--mono); font-size: 11px; color: var(--text-2); }
    .td-muted { color: var(--text-2); }
    .td-name  { font-weight: 500; }

    /* ── Pills ── */
    .ls-pill {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 3px 9px; border-radius: 20px; font-size: 11.5px; font-weight: 600;
    }

    .ls-pill-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

    .pill-active    { background: var(--success-bg); color: var(--success); }
    .pill-suspended { background: var(--warning-bg); color: var(--warning); }
    .pill-revoked   { background: var(--danger-bg);  color: var(--danger);  }
    .pill-expired   { background: rgba(255,255,255,.07); color: var(--text-3); }

    /* ── Form fields ── */
    .ls-form-group { margin-bottom: 16px; }

    .ls-label {
      display: block; font-size: 11px; letter-spacing: .06em; text-transform: uppercase;
      color: var(--text-3); margin-bottom: 6px; font-weight: 500;
    }

    .ls-input, .ls-select, .ls-textarea {
      width: 100%; background: var(--surf-hi); border: 1px solid var(--border);
      border-radius: 7px; padding: 9px 12px; color: var(--text);
      font-size: 13.5px; font-family: inherit; outline: none;
      transition: border-color .13s;
    }

    .ls-input:focus, .ls-select:focus, .ls-textarea:focus {
      border-color: rgba(0,212,170,.35);
    }

    .ls-input::placeholder { color: var(--text-3); }

    /* ── Filter bar ── */
    .ls-filter { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }

    .ls-search-wrap { position: relative; flex: 1; max-width: 320px; }
    .ls-search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text-3); }

    .ls-search-input {
      width: 100%; background: var(--surf); border: 1px solid var(--border);
      border-radius: 7px; padding: 7px 12px 7px 32px; color: var(--text);
      font-size: 13px; font-family: inherit; outline: none; transition: border-color .13s;
    }

    .ls-search-input:focus { border-color: rgba(0,212,170,.35); }
    .ls-search-input::placeholder { color: var(--text-3); }

    .ls-filter-select {
      background: var(--surf); border: 1px solid var(--border);
      border-radius: 7px; padding: 7px 10px; color: var(--text);
      font-size: 13px; font-family: inherit; cursor: pointer; outline: none;
    }

    /* ── Alerts ── */
    .ls-alert {
      padding: 11px 16px; border-radius: 7px; font-size: 13px; margin-bottom: 14px;
      display: flex; align-items: center; gap: 8px;
    }

    .ls-alert-danger { background: var(--danger-bg); color: var(--danger); border: 1px solid rgba(239,68,68,.2); }

    /* ── Tab nav ── */
    .ls-tabs {
      display: flex; gap: 2px; border-bottom: 1px solid var(--border); margin-bottom: 16px;
    }

    .ls-tab {
      padding: 8px 16px; font-size: 13px; color: var(--text-2); cursor: pointer;
      border-bottom: 2px solid transparent; margin-bottom: -1px;
      text-decoration: none; transition: color .12s;
    }

    .ls-tab.active { color: var(--accent); border-bottom-color: var(--accent); font-weight: 500; }
    .ls-tab:hover:not(.active) { color: var(--text); }

    /* ── Misc ── */
    .text-muted-2 { color: var(--text-2); }
    .text-accent  { color: var(--accent); }
    .text-success { color: var(--success) !important; }
    .text-warning { color: var(--warning) !important; }
    .text-danger  { color: var(--danger)  !important; }
    .font-mono    { font-family: var(--mono); }

    @@media (max-width: 768px) {
      .ls-sidebar { width: 56px; }
      .ls-brand-name, .ls-brand-sub, .ls-nav-section,
      .ls-nav a span, .ls-user-name { display: none; }
    }
  </style>
</head>
<body>

<!-- ── Sidebar ── -->
<aside class="ls-sidebar">
  <div class="ls-brand">
    <div class="ls-brand-icon">🔑</div>
    <div>
      <div class="ls-brand-name">LicenseServer</div>
      <div class="ls-brand-sub">Admin</div>
    </div>
  </div>

  <nav class="ls-nav">
    <div class="ls-nav-section">Overview</div>
    <a href="/admin" class="@(ViewData["Nav"]?.ToString() == "dashboard" ? "active" : "")">
      <span>⬛</span> <span>Dashboard</span>
    </a>

    <div class="ls-nav-section">Management</div>
    <a href="/admin/customers" class="@(ViewData["Nav"]?.ToString() == "customers" ? "active" : "")">
      <span>👥</span> <span>Customers</span>
    </a>
    <a href="/admin/licenses" class="@(ViewData["Nav"]?.ToString() == "licenses" ? "active" : "")">
      <span>🗝</span> <span>Licenses</span>
    </a>

    <div class="ls-nav-section">Monitoring</div>
    <a href="/admin/activity" class="@(ViewData["Nav"]?.ToString() == "activity" ? "active" : "")">
      <span>📋</span> <span>Activity Log</span>
    </a>
  </nav>

  <div class="ls-footer">
    <div class="ls-user">
      <div class="ls-avatar">A</div>
      <div class="ls-user-name">@User.Identity?.Name</div>
      <form method="post" action="/admin/logout">
        @Html.AntiForgeryToken()
        <button type="submit" class="ls-logout" title="Sign out">↪</button>
      </form>
    </div>
  </div>
</aside>

<!-- ── Main ── -->
<main class="ls-main" style="overflow-y:auto;height:100vh">
  @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmf1fyKnH2dMV7uY+Gy5DqCMM7"
        crossorigin="anonymous"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
